PORT=3000
NODE_ENV=development

# Directory where content.json is persisted. On Railway this should be the
# mount path of an attached volume (e.g. /data) so edits survive redeploys.
DATA_DIR=./data

# Admin login (single admin, no signup routes exist at all)
ADMIN_EMAIL=admin@example.com
# bcrypt hash of the admin password - never put the plaintext password here
ADMIN_PASSWORD_HASH=

# Long random string used to sign admin session JWTs
JWT_SECRET=
